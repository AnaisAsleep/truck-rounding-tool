# Airtable credentials — copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Your Airtable Personal Access Token (starts with pat...)
AIRTABLE_API_KEY=your_airtable_api_key_here

# Your Airtable Base ID (starts with app...)
AIRTABLE_BASE_ID=your_base_id_here

# Table IDs (recommended) or Table Names
# Using IDs is more reliable — find them in the Airtable API docs for your base
PALLETIZATION_TABLE_ID=tblY2PxdLq84p8Erc
COST_TABLE_ID=tbl6Vr4XwyNhLVsMX
